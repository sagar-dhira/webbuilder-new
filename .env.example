# API - use /api when dev server proxies to framely backend (avoids CORS)
VITE_API_URL=/api

# Superset - for chart embeds
VITE_SUPERSET_BASE_URL=http://localhost:8088

# Auth: webbuilder uses framely backend. Ensure framely backend runs on 3001
# and has JWT_SECRET set. Register users at POST /api/auth/register

# Keycloak (optional) - when set, login uses Keycloak SSO instead of email/password
# Backend must have matching KEYCLOAK_URL, KEYCLOAK_REALM for token exchange
# VITE_KEYCLOAK_URL=https://login.akashic.dhira.io
# VITE_KEYCLOAK_REALM=development
# VITE_KEYCLOAK_CLIENT_ID=akashic-dev

# ETL widget defaults (used when drag-and-drop)
VITE_ETL_API_URL=https://api-dev.akashic.dhira.io/application/data_flow/list
VITE_ETL_TENANT_NAME=tenanta
VITE_ETL_DEFAULT_BODY={"pipeline_name":"","limit":"","page_number":1,"filterStatus":"","data_flow_type":"ETL"}
# ETL API expects Keycloak token (not framely JWT). Set your Akashic/Keycloak token here.
# VITE_ETL_API_TOKEN=your_keycloak_access_token
